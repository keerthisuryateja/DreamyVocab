<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.vocabulary.UIController"
            stylesheets="@dreamy.css"
            prefWidth="820" prefHeight="580">

    <!-- TOP: Header -->
    <top>
        <HBox styleClass="header" spacing="10" alignment="CENTER_LEFT">
            <padding><Insets top="11" right="14" bottom="11" left="14"/></padding>
            <Button fx:id="sidebarToggleBtn" text="◀" onAction="#onToggleSidebar" styleClass="icon-btn"/>
            <Label text="🌸 Dreamy Vocab" styleClass="app-title" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Label fx:id="todayBadge" text="Today: 0" styleClass="badge"/>
            <Label fx:id="totalBadge" text="Total: 0" styleClass="badge"/>
            <Separator orientation="VERTICAL" styleClass="hdr-sep"/>
            <Button text="A−" onAction="#onZoomOut" styleClass="zoom-btn"/>
            <Button text="A+" onAction="#onZoomIn" styleClass="zoom-btn"/>
            <Button text="↺" onAction="#onZoomReset" styleClass="zoom-btn"/>
        </HBox>
    </top>

    <!-- LEFT: Word history sidebar -->
    <left>
        <VBox fx:id="sidebarPane" styleClass="sidebar" spacing="8">
            <padding><Insets top="14" right="8" bottom="14" left="12"/></padding>
            <Label text="📖 My Words" styleClass="sidebar-title"/>
            <TextField fx:id="historyFilter" promptText="Filter…" styleClass="filter-box"
                       onKeyReleased="#onFilterHistory"/>
            <ListView fx:id="historyList" styleClass="history-list" VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <!-- CENTER: Search + result card -->
    <center>
        <VBox styleClass="main-area" spacing="10">
            <padding><Insets top="16" right="20" bottom="14" left="14"/></padding>

            <!-- Search row -->
            <HBox spacing="8" alignment="CENTER">
                <TextField fx:id="searchField" promptText="Enter a word…"
                           styleClass="search-box" HBox.hgrow="ALWAYS" onAction="#onSearch"/>
                <ComboBox fx:id="sourceCombo" styleClass="source-combo"/>
                <Button fx:id="searchBtn" text="Search" onAction="#onSearch" styleClass="search-btn"/>
                <Button fx:id="quizStartBtn" text="Quiz Last Words" onAction="#onStartQuiz" styleClass="quiz-start-btn"/>
            </HBox>

            <Label fx:id="statusLabel" text="" styleClass="status-label"/>

            <!-- Quiz panel -->
            <VBox fx:id="quizPane" styleClass="quiz-pane" spacing="8" visible="false" managed="false">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="🧠 Quiz" styleClass="quiz-title"/>
                    <Label fx:id="quizProgressLabel" text="" styleClass="quiz-progress"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="quizSummaryLabel" text="" styleClass="quiz-summary"/>
                </HBox>

                <Label fx:id="quizWordLabel" text="" styleClass="quiz-word"/>

                <VBox spacing="6">
                    <RadioButton fx:id="quizOptionA" styleClass="quiz-option" wrapText="true"/>
                    <RadioButton fx:id="quizOptionB" styleClass="quiz-option" wrapText="true"/>
                    <RadioButton fx:id="quizOptionC" styleClass="quiz-option" wrapText="true"/>
                    <RadioButton fx:id="quizOptionD" styleClass="quiz-option" wrapText="true"/>
                </VBox>

                <Label fx:id="quizFeedbackLabel" text="" styleClass="quiz-feedback"/>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Button fx:id="quizSubmitBtn" text="Submit Answer" onAction="#onSubmitQuizAnswer" styleClass="quiz-action-btn"/>
                    <Button fx:id="quizNextBtn" text="Next" onAction="#onNextQuizQuestion"
                            styleClass="quiz-action-btn" visible="false" managed="false"/>
                    <Button fx:id="retryWrongBtn" text="Retry Incorrect" onAction="#onRetryWrongQuiz"
                            styleClass="quiz-retry-btn" visible="false" managed="false"/>
                </HBox>

                <Label text="Recent quiz history" styleClass="quiz-history-title"/>
                <ListView fx:id="quizHistoryList" styleClass="quiz-history-list" maxHeight="110"/>
            </VBox>

            <!-- Empty / welcome state -->
            <VBox fx:id="emptyState" alignment="CENTER" VBox.vgrow="ALWAYS" spacing="8">
                <Label text="✨" style="-fx-font-size: 2.4em;"/>
                <Label text="Search a word to get started" styleClass="empty-hint"/>
                <Label text="Tip: press Enter to search, Escape to clear" styleClass="empty-sub-hint"/>
            </VBox>

            <!-- Result card (hidden until a word is looked up) -->
            <VBox fx:id="cardArea" styleClass="card" spacing="10"
                  VBox.vgrow="ALWAYS" visible="false" managed="false">

                <!-- Word title row -->
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label fx:id="wordLabel" styleClass="word-title"/>
                    <Button text="🔊" onAction="#onTTS" styleClass="icon-btn tts-btn"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="sourceLabel" styleClass="source-text"/>
                    <Button fx:id="editBtn" text="Edit" onAction="#onEdit" styleClass="action-btn"/>
                    <Button fx:id="cancelEditBtn" text="Cancel" onAction="#onCancelEdit"
                            styleClass="cancel-btn" visible="false" managed="false"/>
                    <Button text="Delete" onAction="#onDelete" styleClass="delete-btn"/>
                </HBox>

                <Separator style="-fx-background-color: #EFE0F8;"/>

                <TextArea fx:id="meaningArea" styleClass="meaning-text" wrapText="true"
                          editable="false" VBox.vgrow="ALWAYS"/>

                <ListView fx:id="suggestionList" styleClass="suggestion-list"
                          visible="false" managed="false" maxHeight="130"/>

            </VBox>

        </VBox>
    </center>

</BorderPane>
